{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/gen-config.mjs",
  "installCommand": "echo no-deps",
  "outputDirectory": "ui",
  "framework": null,
  "headers": [
    {
      "source": "/config.js",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
